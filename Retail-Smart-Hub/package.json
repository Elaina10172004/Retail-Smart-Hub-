{
  "name": "retail-smart-hub",
  "private": true,
  "version": "0.0.0",
  "description": "Retail Smart Hub desktop logistics and retail operations system",
  "author": "retail-smart-hub",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.14.0 <25",
    "npm": ">=10.9.2 <12"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "runtime:check": "node ./scripts/runtime-check.mjs",
    "guard:ai-python-first": "node ./scripts/guard-ai-python-first.mjs",
    "clean:release": "node ./scripts/clean-release-workspace.mjs",
    "install:clean": "node ./scripts/clean-install.mjs",
    "preflight:release": "node ./scripts/release-preflight.mjs",
    "release:desktop": "node ./scripts/release-build.mjs",
    "release:ci": "node ./scripts/release-build.mjs --ci",
    "release:rollback": "node ./scripts/release-rollback.mjs",
    "release:source": "node ./scripts/export-release-source.mjs",
    "python:deps:install": "python -m pip install --upgrade pip && python -m pip install -r python-agent/requirements.txt",
    "dev": "vite --port=3000 --host=127.0.0.1",
    "dev:server": "tsx watch --exclude \"database/**\" --exclude \"**/*.db\" --exclude \"**/*.db-wal\" --exclude \"**/*.db-shm\" server/src/index.ts",
    "desktop:dev": "node ./scripts/dev-desktop.mjs",
    "desktop:start": "node ./scripts/start-electron.cjs",
    "build:server": "tsc -p tsconfig.server.json && node ./scripts/finalize-server-build.mjs",
    "build:web": "vite build",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:build": "npm run build && electron-builder -w",
    "prebuild": "node ./scripts/ensure-platform-install.mjs",
    "build": "npm run build:server && npm run build:web",
    "rag:rebuild": "npm run build:server && node ./dist-server/modules/ai/rag.cli.js rebuild --incremental true",
    "rag:rebuild:full": "npm run build:server && node ./dist-server/modules/ai/rag.cli.js rebuild --force true --incremental false",
    "rag:eval": "npm run build:server && node ./dist-server/modules/ai/rag.cli.js eval --dataset ./public/templates/rag-eval-sample.json --k 3",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('dist-server',{recursive:true,force:true});\"",
    "test:server": "node -e \"console.log('No server TypeScript tests are included in this source package.')\"",
    "test:python-agent": "python -c \"import fastapi,uvicorn,pydantic,lancedb\" && cd python-agent && python -m unittest discover -s tests -p \"test_*.py\"",
    "test:web": "node -e \"console.log('No web TSX tests are included in this source package.')\"",
    "pretest": "node ./scripts/ensure-platform-install.mjs",
    "test": "npm run test:server && npm run test:web && npm run test:python-agent",
    "pretypecheck": "node ./scripts/ensure-platform-install.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.17.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^39.2.6",
    "electron-builder": "^24.13.3",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.retailsmarthub.desktop",
    "productName": "Retail Smart Hub",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "artifacts/desktop"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron/**/*",
      "python-agent/**/*",
      "public/**/*",
      {
        "from": "../docs/rag/knowledge",
        "to": "docs/rag/knowledge",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
