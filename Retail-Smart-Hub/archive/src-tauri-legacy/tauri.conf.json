{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Retail Smart Hub",
  "version": "0.1.0",
  "identifier": "com.retailsmarthub.desktop",
  "build": {
    "beforeDevCommand": "npm run desktop:dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Retail Smart Hub",
        "width": 1480,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
