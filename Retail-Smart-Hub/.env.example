# Replace the placeholder below with your DeepSeek API key.
DEEPSEEK_API_KEY=REPLACE_WITH_YOUR_DEEPSEEK_API_KEY
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_PROVIDER=deepseek
AI_SMALL_PROVIDER=deepseek
AI_SMALL_BASE_URL=https://api.deepseek.com
AI_SMALL_MODEL=deepseek-chat
AI_SMALL_API_KEY=
AI_LARGE_PROVIDER=deepseek
AI_LARGE_BASE_URL=https://api.deepseek.com
AI_LARGE_MODEL=deepseek-reasoner
AI_LARGE_API_KEY=
AI_RUNTIME=python
AI_PYTHON_HOST=127.0.0.1
AI_PYTHON_PORT=18080
AI_PYTHON_COMMAND=python
AI_PYTHON_AUTOSTART=true
# Leave AI_AGENT_SHARED_KEY empty unless you intentionally want to pin a custom local bridge key.
AI_AGENT_SHARED_KEY=
AI_AGENT_REQUEST_TIMEOUT_MS=120000
AI_MOCK_FALLBACK=false
VITE_API_BASE_URL=/api
VITE_SERVER_PROXY_TARGET=http://localhost:4000
API_HOST=127.0.0.1
API_PORT=4000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_NULL_ORIGIN=false
AUTH_DEBUG_EXPOSE_RESET_TOKEN=false
AUTH_DEBUG_LOG_SEED_PASSWORDS=false

# RAG v2 (memory-lancedb-pro style) tuning
RAG_RETRIEVAL_MODE=hybrid
RAG_SCOPE_DEFAULT=all
RAG_TOP_K=3
RAG_CANDIDATE_K=18
RAG_MIN_SCORE=0.18
RAG_DENSE_WEIGHT=0.42
RAG_LEXICAL_WEIGHT=0.48
RAG_MMR_LAMBDA=0.72
RAG_RECENCY_HALF_LIFE_DAYS=45
RAG_LANCEDB_ENABLED=true
RAG_LANCEDB_DIR=database/rag/lancedb
RAG_LANCEDB_TABLE=knowledge_chunks
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
RAG_EMBEDDING_API_KEY=REPLACE_WITH_EMBEDDING_API_KEY
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_BATCH_SIZE=24
RAG_EMBEDDING_DIMENSIONS=1536
RAG_VECTOR_CANDIDATE_K=32
RAG_FTS_CANDIDATE_K=32
RAG_RERANK_ENABLED=true
RAG_RERANK_PROVIDER=heuristic
RAG_RERANK_BASE_URL=
RAG_RERANK_API_KEY=
RAG_RERANK_MODEL=
RAG_RERANK_TOP_N=20
RAG_ADAPTIVE_RETRIEVE_ENABLED=true
RAG_MEMORY_ENABLED=true
RAG_MEMORY_RETENTION_DAYS=60

# Layered agent runtime
AI_LAYERED_AGENT_ENABLED=true
AI_LAYERED_MAX_EXECUTE_ROUNDS=2
AI_LAYERED_CONTEXT_CHAR_BUDGET=12000
AI_LAYERED_WEB_FALLBACK_MAX_ROUNDS=1
AI_LAYERED_CONSOLE_LOG=true
AI_LAYERED_CONSOLE_LOG_MAX_CHARS=320
AI_MODEL_IO_CONSOLE_LOG=true
AI_MODEL_IO_CONSOLE_LOG_MAX_CHARS=0

# Tavily web search
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_TOPIC=general
TAVILY_MAX_RESULTS=5

# Local Ollama example:
# RAG_EMBEDDING_PROVIDER=ollama
# RAG_EMBEDDING_BASE_URL=http://127.0.0.1:11434
# RAG_EMBEDDING_MODEL=nomic-embed-text
# RAG_EMBEDDING_API_KEY=
# RAG_EMBEDDING_DIMENSIONS=0

# Optional remote rerank examples:
# RAG_RERANK_PROVIDER=jina
# RAG_RERANK_BASE_URL=https://api.jina.ai
# RAG_RERANK_API_KEY=REPLACE_WITH_RERANK_KEY
# RAG_RERANK_MODEL=jina-reranker-v2-base-multilingual
